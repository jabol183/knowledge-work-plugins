<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ shop.name }} — Coming Soon</title>
  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}
  {{ content_for_header }}
  {% render 'css-variables' %}
  <link rel="stylesheet" href="{{ 'theme.css' | asset_url }}">
  <style>
    .password-page { min-height: 100vh; display: grid; grid-template-rows: auto 1fr auto; background: var(--color-background); }
    .password-header { display: flex; align-items: center; justify-content: space-between; padding: 4rem var(--container-gutter); }
    .password-logo { font-family: var(--font-heading-family); font-size: var(--font-size-lg); letter-spacing: 0.12em; text-transform: uppercase; color: var(--color-text-primary); text-decoration: none; }
    .password-main { display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: var(--space-9) var(--container-gutter); }
    .password-eyebrow { font-size: var(--font-size-xs); letter-spacing: 0.18em; text-transform: uppercase; color: var(--color-text-secondary); margin-bottom: var(--space-5); }
    .password-heading { font-family: var(--font-heading-family); font-size: clamp(var(--font-size-2xl), 8vw, var(--font-size-4xl)); letter-spacing: var(--font-heading-letter-spacing); color: var(--color-text-primary); margin-bottom: var(--space-6); line-height: 1.05; }
    .password-subheading { font-size: var(--font-size-base); color: var(--color-text-secondary); max-width: 44rem; margin: 0 auto var(--space-8); }
    .password-form { display: flex; gap: 0; max-width: 40rem; width: 100%; }
    .password-input { flex: 1; height: var(--btn-height); padding: 0 var(--space-5); border: 1px solid var(--color-border); border-right: none; font-size: var(--font-size-sm); font-family: var(--font-body-family); background: transparent; outline: none; color: var(--color-text-primary); }
    .password-input:focus { border-color: var(--color-text-primary); }
    .password-footer { text-align: center; padding: var(--space-6) var(--container-gutter); border-top: 1px solid var(--color-border); font-size: var(--font-size-xs); color: var(--color-text-secondary); }
    .password-footer a { color: inherit; }
    .password-admin { font-size: var(--font-size-xs); color: var(--color-text-secondary); }
    .password-admin a { color: var(--color-text-primary); text-decoration: none; border-bottom: 1px solid currentColor; }
  </style>
</head>
<body class="password-page">

  <header class="password-header">
    <a href="/" class="password-logo">{{ shop.name }}</a>
    <p class="password-admin">
      <a href="/password">{{ 'general.password_page.admin_link_html' | t | default: 'Store admin' }}</a>
    </p>
  </header>

  <main class="password-main">
    <p class="password-eyebrow">{{ 'general.password_page.coming_soon' | t | default: 'Coming Soon' }}</p>
    <h1 class="password-heading">{{ shop.name }}</h1>

    {%- if shop.password_message != blank -%}
      <p class="password-subheading">{{ shop.password_message }}</p>
    {%- else -%}
      <p class="password-subheading">We&rsquo;re working on something beautiful. Enter the password to get early access.</p>
    {%- endif -%}

    {{ content_for_layout }}
  </main>

  <footer class="password-footer">
    <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
  </footer>

</body>
</html>
