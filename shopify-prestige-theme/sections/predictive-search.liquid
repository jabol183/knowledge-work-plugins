<div
  class="search-modal__header"
  style="display: flex; align-items: center; gap: var(--space-4); padding: var(--space-5) var(--container-gutter); border-bottom: 1px solid var(--color-border);"
>
  {% render 'icon-pack', icon: 'search' %}
  <form action="{{ routes.search_url }}" method="get" role="search" style="flex: 1;">
    <input type="hidden" name="type" value="product">
    <input
      class="search-modal__input"
      type="search"
      name="q"
      id="predictive-search-input"
      placeholder="{{ 'search.placeholder' | t | default: 'Search products, collections...' }}"
      autocomplete="off"
      autocorrect="off"
      autocapitalize="off"
      spellcheck="false"
      aria-label="{{ 'search.search' | t | default: 'Search' }}"
      aria-autocomplete="list"
      aria-controls="predictive-search-results"
      aria-expanded="false"
      role="combobox"
    >
  </form>
  <button
    class="site-header__icon-btn"
    data-search-close
    aria-label="{{ 'accessibility.close' | t | default: 'Close search' }}"
  >
    {% render 'icon-pack', icon: 'close' %}
  </button>
</div>

<div
  class="search-modal__results"
  id="predictive-search-results"
  role="listbox"
  aria-label="{{ 'search.results' | t | default: 'Search results' }}"
>
  <div class="search-results" id="search-results-container">
    {%- comment -%} Populated via JS / section render {%- endcomment -%}
    {%- if search.performed -%}
      {%- if search.results_count > 0 -%}
        <p class="search-results__heading">
          {{ 'search.results_with_count' | t: count: search.results_count | default: 'Results' }}
        </p>
        <div class="search-results__grid">
          {%- for result in search.results limit: 8 -%}
            {%- if result.object_type == 'product' -%}
              {% render 'product-card', product: result %}
            {%- else -%}
              <a href="{{ result.url }}" class="search-results__item">
                <p class="body-sm">{{ result.title }}</p>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <p class="text-secondary text-center" style="padding: var(--space-9) 0;">
          {{ 'search.no_results' | t: terms: search.terms | default: 'No results found.' }}
        </p>
      {%- endif -%}
    {%- else -%}
      <p class="eyebrow text-center" style="padding: var(--space-9) 0; opacity: 0.4;">
        {{ 'search.prompt' | t | default: 'Start typing to search...' }}
      </p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Predictive search",
  "settings": []
}
{% endschema %}
