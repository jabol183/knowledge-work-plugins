<article class="container" style="max-width: 84rem; padding-top: calc(var(--header-height) + var(--space-7)); padding-bottom: var(--space-9);">

  <header style="margin-bottom: var(--space-7); padding-bottom: var(--space-6); border-bottom: 1px solid var(--color-border);" data-animate>
    <div style="display: flex; gap: var(--space-3); margin-bottom: var(--space-4); flex-wrap: wrap;">
      {%- for tag in article.tags -%}
        <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="eyebrow" style="color: var(--color-text-secondary);">{{ tag }}</a>
      {%- endfor -%}
    </div>
    <h1 class="heading-md" style="margin-bottom: var(--space-4);">{{ article.title }}</h1>
    <div class="body-xs text-secondary" style="display: flex; gap: var(--space-4); align-items: center;">
      {%- if article.author != blank -%}<span>{{ article.author }}</span><span aria-hidden="true">—</span>{%- endif -%}
      <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%B %d, %Y' }}</time>
    </div>
  </header>

  {%- if article.image -%}
    <figure style="margin-bottom: var(--space-7); aspect-ratio: 16/9; overflow: hidden;" data-animate data-animate-delay="1">
      {{ article.image | image_url: width: 1600 | image_tag: loading: 'eager', fetchpriority: 'high', alt: article.image.alt | escape }}
    </figure>
  {%- endif -%}

  <div class="rte body-lg" style="max-width: 72rem;" data-animate data-animate-delay="2">
    {{ article.content }}
  </div>

  <footer style="margin-top: var(--space-8); padding-top: var(--space-6); border-top: 1px solid var(--color-border);">
    <a href="{{ blog.url }}" class="btn btn--ghost">
      {% render 'icon-pack', icon: 'chevron-left' %}
      {{ 'blogs.article.back_to_blog' | t | default: 'Back to' }} {{ blog.title }}
    </a>
  </footer>

</article>

{% schema %}
{
  "name": "Article",
  "settings": []
}
{% endschema %}
